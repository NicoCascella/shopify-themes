{% doc %}
  Renders a grid of services from metaobjects.
  Each service card displays name, description, featured image and gallery.

  @example
  {% section 'services-list' %}
{% enddoc %}

<section class="services-list" {{ section.shopify_attributes }}>
  <div class="services-list__container">
    {% assign services = metaobjects.service.values %}

    {% if services.size > 0 %}
      <h1 class="services-list__title">{{ section.settings.title }}</h1>

      <div class="services-list__grid">
        {% for service in services %}
          <article class="service-card" data-service-id="{{ service.slug }}">
            <!-- Featured Image -->
            {% if service.image %}
              <div class="service-card__image-wrapper">
                <img
                  src="{{ service.image | image_url: width: 500, height: 400 }}"
                  alt="{{ service.name }}"
                  class="service-card__image"
                  loading="lazy"
                >
              </div>
            {% endif %}

            <!-- Content -->
            <div class="service-card__content">
              <h2 class="service-card__title">{{ service.name }}</h2>

              <div class="service-card__description">
                {{ service.description | metafield_text }}
              </div>

              <!-- Gallery Indicator -->
              {% if service.gallery and service.gallery.size > 0 %}
                <div class="service-card__gallery-info">
                  <span class="service-card__gallery-badge">
                    📸 {{ service.gallery.size }} {% if service.gallery.size == 1 %}foto{% else %}foto{% endif %}
                  </span>
                </div>
              {% endif %}

              <!-- CTA Button -->
              <a
                href="/services?service={{ service.slug }}"
                class="service-card__cta button button--primary"
              >
                {{ section.settings.button_text }}
              </a>
            </div>
          </article>
        {% endfor %}
      </div>
    {% else %}
      <div class="services-list__empty">
        <p>{{ section.settings.empty_state }}</p>
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .services-list {
    width: 100%;
    padding: var(--spacing-2xl) var(--spacing-lg);
    background: var(--color-brand-beige);
    position: relative;
    overflow: hidden;
  }

  .services-list::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: radial-gradient(var(--color-brand-gold-soft) 1px, transparent 1px);
    background-size: 40px 40px;
    opacity: 0.3;
    pointer-events: none;
  }

  .services-list__container {
    max-width: var(--page-width);
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .services-list__title {
    text-align: center;
    margin-bottom: var(--spacing-2xl);
    font-family: var(--font-serif);
    color: var(--color-brand-brown);
    font-size: clamp(2rem, 4vw, 3rem);
    position: relative;
    display: inline-block;
    left: 50%;
    transform: translateX(-50%);
  }

  .services-list__title::after {
    content: '';
    position: absolute;
    bottom: -10px;
    left: 25%;
    width: 50%;
    height: 1px;
    background: var(--color-brand-gold);
  }

  .services-list__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: var(--spacing-xl);
    margin-bottom: var(--spacing-2xl);
  }

  /* Service Card */
  .service-card {
    background: var(--color-white);
    border-radius: var(--border-radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-base);
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
  }

  .service-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-brand-gold-soft);
  }

  .service-card__image-wrapper {
    position: relative;
    width: 100%;
    padding-bottom: 66.6%; /* 3:2 aspect ratio for more elegance */
    overflow: hidden;
    background: var(--color-brand-lion);
  }

  .service-card__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1.5s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .service-card:hover .service-card__image {
    transform: scale(1.1);
  }

  .service-card__content {
    padding: var(--spacing-xl);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    text-align: center;
  }

  .service-card__title {
    margin: 0 0 var(--spacing-sm) 0;
    font-family: var(--font-serif);
    color: var(--color-brand-brown);
    font-size: 1.75rem;
  }

  .service-card__description {
    color: var(--color-text-light);
    line-height: 1.7;
    font-size: 1rem;
    margin-bottom: var(--spacing-lg);
    flex-grow: 1;
  }

  .service-card__gallery-info {
    margin-bottom: var(--spacing-lg);
  }

  .service-card__gallery-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-brand-lion);
    color: var(--color-brand-brown);
    padding: var(--spacing-xs) var(--spacing-md);
    border-radius: 100px;
    font-size: 0.85rem;
    font-weight: 600;
    border: 1px solid var(--color-brand-gold-soft);
  }

  .service-card__cta {
    margin-top: auto;
    width: 100%;
  }

  .services-list__empty {
    text-align: center;
    padding: var(--spacing-2xl);
    color: var(--color-text-light);
    font-style: italic;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .services-list {
      padding: var(--spacing-xl) var(--spacing-md);
    }

    .services-list__grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .service-card__content {
      padding: var(--spacing-lg);
    }
  }
{% endstylesheet %}


{% schema %}
{
  "name": "Services List",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Titolo sezione",
      "default": "I Nostri Servizi"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Testo bottone",
      "default": "Scopri di più"
    },
    {
      "type": "text",
      "id": "empty_state",
      "label": "Messaggio nessun servizio",
      "default": "Nessun servizio disponibile al momento"
    }
  ],
  "presets": [
    {
      "name": "Services List"
    }
  ]
}
{% endschema %}
