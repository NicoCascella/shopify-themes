{% doc %}
  Catering page section — editorial layout with highlights and CTA.

  @example
  {% section 'catering' %}
{% enddoc %}

<!-- Catering hero -->
<section class="page-hero">
  <div class="page-hero__media">
    {%- if section.settings.hero_image -%}
      <img
        src="{{ section.settings.hero_image | image_url: width: 2400 }}"
        alt="{{ section.settings.hero_image.alt | default: 'Catering' | escape }}"
        loading="eager"
        fetchpriority="high"
      >
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag }}
    {%- endif -%}
    <div class="page-hero__overlay"></div>
  </div>
  <div class="container">
    <div class="page-hero__content fade-in">
      <span class="eyebrow" style="color:rgba(255,255,255,.65)">{{ section.settings.eyebrow }}</span>
      <h1>{{ section.settings.hero_title }}</h1>
      <p style="color:rgba(255,255,255,.8);margin-top:1rem;font-size:.95rem;max-width:48ch">{{ section.settings.hero_subtitle }}</p>
    </div>
  </div>
</section>

<!-- Editorial content -->
<section class="page-content section">
  <div class="container">

    <div class="editorial-grid fade-in">
      <div class="editorial-image">
        {%- if section.settings.content_image -%}
          <img
            src="{{ section.settings.content_image | image_url: width: 1000 }}"
            alt="{{ section.settings.content_image.alt | escape }}"
            loading="lazy"
          >
        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag }}
        {%- endif -%}
      </div>
      <div class="editorial-text">
        <span class="eyebrow">{{ section.settings.content_eyebrow }}</span>
        <h2>{{ section.settings.content_title }}</h2>
        <div class="section-divider"></div>
        <p>{{ section.settings.content_text }}</p>
        {%- if section.settings.cta_label != blank -%}
          <div style="margin-top:2rem">
            <a href="{{ section.settings.cta_url | default: '/pages/contatti' }}" class="btn btn--accent">
              <span>{{ section.settings.cta_label }}</span>
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>

    <!-- Highlights bar -->
    {%- if section.blocks.size > 0 -%}
      <div class="highlights fade-in">
        {%- for block in section.blocks -%}
          <div class="highlight-item" {{ block.shopify_attributes }}>
            <span class="highlight-item__number">{{ block.settings.number }}</span>
            <span class="highlight-item__label">{{ block.settings.label }}</span>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "t:sections.catering.name",
  "settings": [
    {
      "type": "header",
      "content": "t:headers.hero"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "t:labels.image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Servizio catering"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "t:labels.title",
      "default": "Dolci per ogni occasione"
    },
    {
      "type": "text",
      "id": "hero_subtitle",
      "label": "t:labels.subtitle",
      "default": "Offriamo un servizio catering di alta pasticceria per eventi aziendali, matrimoni e ricevimenti privati."
    },
    {
      "type": "header",
      "content": "t:headers.content"
    },
    {
      "type": "image_picker",
      "id": "content_image",
      "label": "t:labels.image"
    },
    {
      "type": "text",
      "id": "content_eyebrow",
      "label": "t:labels.eyebrow",
      "default": "Il nostro approccio"
    },
    {
      "type": "text",
      "id": "content_title",
      "label": "t:labels.title",
      "default": "Un'esperienza su misura"
    },
    {
      "type": "richtext",
      "id": "content_text",
      "label": "t:labels.text",
      "default": "<p>Ogni evento è unico. Lavoriamo a stretto contatto con i nostri clienti per creare menu di pasticceria personalizzati, dalla degustazione alla consegna.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "t:labels.cta_label",
      "default": "Richiedi un preventivo"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "t:labels.link"
    }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "t:blocks.highlight.name",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "t:labels.number",
          "default": "500+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "t:labels.label",
          "default": "eventi realizzati"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.catering.name",
      "blocks": [
        { "type": "highlight", "settings": { "number": "500+", "label": "eventi realizzati" } },
        { "type": "highlight", "settings": { "number": "15+", "label": "anni di esperienza" } },
        { "type": "highlight", "settings": { "number": "100%", "label": "ingredienti italiani" } }
      ]
    }
  ]
}
{% endschema %}
