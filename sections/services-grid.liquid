{% doc %}
  Services preview section with editorial cards linking to catering, events, booking.

  @example
  {% section 'services-grid' %}
{% enddoc %}

<section class="services section">
  <div class="container">

    <div class="section-header section-header--center fade-in">
      {%- if section.settings.eyebrow != blank -%}
        <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.title != blank -%}
        <h2>{{ section.settings.title }}</h2>
      {%- endif -%}
      <div class="section-divider"></div>
    </div>

    <div class="services-grid fade-in">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.url | default: '#' }}" class="service-card" {{ block.shopify_attributes }}>
          <div class="service-card__media">
            {%- if block.settings.image -%}
              <img
                src="{{ block.settings.image | image_url: width: 900 }}"
                alt="{{ block.settings.image.alt | default: block.settings.title | escape }}"
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
              >
            {%- else -%}
              {{ 'lifestyle-2' | placeholder_svg_tag }}
            {%- endif -%}
          </div>
          <div class="service-card__overlay"></div>
          <div class="service-card__body">
            {%- if block.settings.title != blank -%}
              <h3 class="service-card__title">{{ block.settings.title }}</h3>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <p class="service-card__desc">{{ block.settings.description }}</p>
            {%- endif -%}
            {%- if block.settings.cta_label != blank -%}
              <span class="service-card__link">
                {{ block.settings.cta_label }}
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "t:sections.services.name",
  "max_blocks": 3,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "I nostri servizi"
    },
    {
      "type": "text",
      "id": "title",
      "label": "t:labels.title",
      "default": "Molto più di una pasticceria"
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "t:blocks.service.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:labels.title",
          "default": "Catering"
        },
        {
          "type": "text",
          "id": "description",
          "label": "t:labels.description",
          "default": "Dolci su misura per eventi aziendali e privati."
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "t:labels.cta_label",
          "default": "Scopri il servizio"
        },
        {
          "type": "url",
          "id": "url",
          "label": "t:labels.link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.services.name",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "title": "Catering",
            "description": "Dolci su misura per eventi aziendali e privati.",
            "cta_label": "Scopri il servizio"
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Eventi",
            "description": "Torte e buffet dolci per ogni celebrazione.",
            "cta_label": "Scopri il servizio"
          }
        },
        {
          "type": "service",
          "settings": {
            "title": "Prenotazioni",
            "description": "Prenota la tua degustazione o consulenza privata.",
            "cta_label": "Prenota ora"
          }
        }
      ]
    }
  ]
}
{% endschema %}
